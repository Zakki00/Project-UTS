<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.projectuas.LoginController"
           styleClass="root-bg"
           stylesheets="@../styles/login.css">
    <!-- Wrapper utama: selalu CENTER di tengah window -->
    <StackPane styleClass="main-wrapper" alignment="CENTER">
        <!-- Layer 1 (bawah): Left panel penuh mengisi wrapper -->
        <HBox styleClass="panels-container" alignment="CENTER_LEFT">
            <!-- LEFT PANEL — mengisi tinggi penuh wrapper -->
            <VBox styleClass="left-panel" alignment="TOP_CENTER" spacing="0"
                  VBox.vgrow="ALWAYS">
                <Region VBox.vgrow="ALWAYS" />
                <StackPane styleClass="icon-wrapper" alignment="CENTER">
                    <Label styleClass="store-icon" text="&#x1F3EA;" />
                </StackPane>
                <Label styleClass="brand-name" text="StoreMS">
                    <VBox.margin>
                        <Insets top="18" />
                    </VBox.margin>
                </Label>
                <Label styleClass="brand-tagline" text="Sistem Manajemen Toko">
                    <VBox.margin>
                        <Insets top="4" />
                    </VBox.margin>
                </Label>
                <Rectangle styleClass="accent-divider" width="60" height="3" arcWidth="3" arcHeight="3">
                    <VBox.margin>
                        <Insets top="18" bottom="28" />
                    </VBox.margin>
                </Rectangle>
                <VBox styleClass="feature-list" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="feature-item">
                        <Label styleClass="feature-icon" text="&#x229E;" />
                        <Label styleClass="feature-text" text="Dashboard Real-time" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="feature-item">
                        <Label styleClass="feature-icon" text="&#x25A4;" />
                        <Label styleClass="feature-text" text="Manajemen Inventori" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="feature-item">
                        <Label styleClass="feature-icon" text="&#x25A6;" />
                        <Label styleClass="feature-text" text="Kasir &amp; POS" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="feature-item">
                        <Label styleClass="feature-icon" text="&#x25A8;" />
                        <Label styleClass="feature-text" text="Laporan Analitik" />
                    </HBox>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <Label styleClass="version-label" text="v1.0  •  JavaFX 21">
                    <VBox.margin>
                        <Insets bottom="24" />
                    </VBox.margin>
                </Label>
            </VBox>
            <!-- Spacer kanan: ruang tempat right panel akan overlap -->
            <Region HBox.hgrow="ALWAYS" styleClass="right-placeholder" />
        </HBox>
        <!-- Layer 2 (atas): Right panel mengambang di kanan dengan shadow -->
        <VBox styleClass="right-panel-float" alignment="CENTER"
              StackPane.alignment="CENTER_RIGHT">
            <!-- LOGIN CARD -->
            <VBox styleClass="login-card" alignment="TOP_CENTER" spacing="0">
                <VBox alignment="CENTER" spacing="6" styleClass="card-header">
                    <Label styleClass="card-title" text="Selamat Datang!" />
                    <Label styleClass="card-subtitle" text="Masuk ke akun Anda untuk melanjutkan" />
                </VBox>
                <VBox spacing="6" styleClass="field-group">
                    <Label styleClass="field-label" text="Username" />
                    <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="input-icon" text="&#x1F464;" />
                        <TextField fx:id="usernameField"
                                   styleClass="text-input"
                                   promptText="admin@storems.id"
                                   HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                <VBox spacing="6" styleClass="field-group">
                    <Label styleClass="field-label" text="Password" />
                    <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="input-icon" text="&#x1F512;" />
                        <PasswordField fx:id="passwordField"
                                       styleClass="text-input password-input"
                                       promptText="••••••••••••"
                                       HBox.hgrow="ALWAYS" />
                        <TextField fx:id="passwordVisible"
                                   styleClass="text-input password-input"
                                   HBox.hgrow="ALWAYS"
                                   managed="false"
                                   visible="false" />
                        <Button fx:id="togglePasswordBtn"
                                styleClass="eye-btn"
                                text="&#x1F441;"
                                onAction="#togglePasswordVisibility" />
                    </HBox>
                </VBox>
                <HBox alignment="CENTER_LEFT" styleClass="options-row">
                    <CheckBox fx:id="rememberMe" styleClass="remember-check" text="Ingat saya" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Hyperlink styleClass="forgot-link" text="Lupa password?"
                               onAction="#handleForgotPassword" />
                </HBox>
                <Button fx:id="loginBtn"
                        styleClass="login-btn"
                        text="MASUK  →"
                        maxWidth="Infinity"
                        onAction="#handleLogin">
                    <VBox.margin>
                        <Insets top="8" />
                    </VBox.margin>
                </Button>
                <HBox alignment="CENTER" spacing="12" styleClass="separator-row">
                    <Separator HBox.hgrow="ALWAYS" styleClass="separator-line" />
                    <Label styleClass="separator-text" text="atau" />
                    <Separator HBox.hgrow="ALWAYS" styleClass="separator-line" />
                </HBox>
                <Button fx:id="guestBtn"
                        styleClass="guest-btn"
                        text="Masuk sebagai Tamu"
                        maxWidth="Infinity"
                        onAction="#handleGuestLogin" />
                <HBox alignment="CENTER" spacing="8" styleClass="security-badge">
                    <Label styleClass="shield-icon" text="&#x1F6E1;" />
                    <Label styleClass="security-text" text="Koneksi Aman &amp; Terenkripsi" />
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</StackPane>
