<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="825.0" prefWidth="719.0" spacing="10.0" styleClass="detail-root" stylesheets="@../styles/detail_transaksi.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projectuas.DetailTransaksiController">
    <children>
        <!-- ── HEADER PELANGGAN ── -->
        <HBox alignment="CENTER_LEFT" prefHeight="109.0" prefWidth="719.0" spacing="15.0" style="-fx-background-radius: 20;" styleClass="header-box">
            <children>
                <Label styleClass="lbl-pelanggan" text="Pelanggan" />
                <TextField fx:id="tfPelanggan" prefHeight="37.0" prefWidth="570.0" promptText="Masukkan nama pelanggan..." styleClass="tf-pelanggan" HBox.hgrow="ALWAYS" />
            </children>
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </VBox.margin>
        </HBox>
        <!-- ── SCROLL LIST ITEM ── -->
        <ScrollPane fx:id="detailScroll" fitToWidth="true" prefHeight="617.0" prefWidth="719.0" styleClass="detail-scroll" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets />
            </VBox.margin>
        </ScrollPane>
        <!-- ── SUMMARY ── -->
        <VBox styleClass="summary-section">
            <padding>
                <Insets top="16" right="30" bottom="16" left="30"/>
            </padding>
            <!-- Subtotal -->
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="summary-label" text="Subtotal" HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblSubtotal" styleClass="summary-value" text="Rp 0"/>
            </HBox>
            <!-- Pajak -->
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="summary-label" text="Pajak (11%)" HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblPajak" styleClass="summary-value" text="Rp 0"/>
            </HBox>
            <Separator styleClass="summary-sep"/>
            <!-- Total -->
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="total-label" text="TOTAL" HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTotal" styleClass="total-value" text="Rp 0"/>
            </HBox>
        </VBox>
        <!-- ── FOOTER BUTTONS ── -->
        <HBox prefHeight="126.0" prefWidth="719.0" spacing="20.0" styleClass="footer-box">
            <children>
                <Button fx:id="btnSimpan" maxWidth="Infinity" mnemonicParsing="false" onAction="#onSimpanTransaksi" prefHeight="70.0" prefWidth="411.0" styleClass="btn-simpan" text="💾  Simpan Transaksi" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnBatal" maxWidth="Infinity" mnemonicParsing="false" onAction="#onBatalTransaksi" prefHeight="70.0" prefWidth="416.0" styleClass="btn-batal" text="✕  Batalkan Transaksi" HBox.hgrow="ALWAYS" />
            </children>
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
        </HBox>
    </children>
</VBox>
