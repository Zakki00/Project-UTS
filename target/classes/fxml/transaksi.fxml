<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" >
    <stylesheets>
        <URL value="@../styles/transaksi.css"/>

    </stylesheets>
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" minWidth="60" prefWidth="220">
            <!-- Logo Row -->
            <HBox fx:id="logoRow" styleClass="logo-row" alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="logo-icon" text="🏪"/>
                <VBox fx:id="logoBrand" styleClass="logo-brand" spacing="1">
                    <Label styleClass="logo-title" text="StoreMS"/>
                    <Label styleClass="logo-sub" text="Manajemen Toko"/>
                </VBox>
            </HBox>
            <Separator styleClass="sidebar-divider"/>
            <!-- Navigation Menu -->
            <VBox fx:id="navMenu" styleClass="nav-menu" spacing="2" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="10" bottom="10"/>
                </VBox.margin>
                <!-- Dashboard (active) -->
                <HBox fx:id="navDashboard" styleClass="nav-item, nav-active" alignment="CENTER_LEFT"
                              spacing="10" onMouseClicked="#onNavDashboard">
                    <Rectangle styleClass="nav-active-bar" width="3" height="0"/>
                    <Label styleClass="nav-icon" text="⊞"/>
                    <Label fx:id="navLblDashboard" styleClass="nav-label" text="Dashboard"/>
                </HBox>
                <!-- Produk -->
                <HBox fx:id="navProduk" styleClass="nav-item" alignment="CENTER_LEFT"
                              spacing="10" onMouseClicked="#onNavProduk">
                    <Rectangle styleClass="nav-active-bar-hidden" width="3" height="0"/>
                    <Label styleClass="nav-icon" text="📦"/>
                    <Label fx:id="navLblProduk" styleClass="nav-label" text="Produk"/>
                </HBox>
                <!-- Kasir -->
                <HBox fx:id="navKasir" styleClass="nav-item" alignment="CENTER_LEFT"
                              spacing="10" onMouseClicked="#onNavKasir">
                    <Rectangle styleClass="nav-active-bar-hidden" width="3" height="0"/>
                    <Label styleClass="nav-icon" text="🛒"/>
                    <Label fx:id="navLblKasir" styleClass="nav-label" text="Kasir"/>
                </HBox>
                <!-- Pelanggan -->
                <HBox fx:id="navPelanggan" styleClass="nav-item" alignment="CENTER_LEFT"
                              spacing="10" onMouseClicked="#onNavPelanggan">
                    <Rectangle styleClass="nav-active-bar-hidden" width="3" height="0"/>
                    <Label styleClass="nav-icon" text="👥"/>
                    <Label fx:id="navLblPelanggan" styleClass="nav-label" text="Pelanggan"/>
                </HBox>
                <!-- Laporan -->
                <HBox fx:id="navLaporan" styleClass="nav-item" alignment="CENTER_LEFT"
                              spacing="10" onMouseClicked="#onNavLaporan">
                    <Rectangle styleClass="nav-active-bar-hidden" width="3" height="0"/>
                    <Label styleClass="nav-icon" text="📈"/>
                    <Label fx:id="navLblLaporan" styleClass="nav-label" text="Laporan"/>
                </HBox>
                <!-- Pengaturan -->
                <HBox fx:id="navPengaturan" styleClass="nav-item" alignment="CENTER_LEFT"
                              spacing="10" onMouseClicked="#onNavPengaturan">
                    <Rectangle styleClass="nav-active-bar-hidden" width="3" height="0"/>
                    <Label styleClass="nav-icon" text="⚙️"/>
                    <Label fx:id="navLblPengaturan" styleClass="nav-label" text="Pengaturan"/>
                </HBox>
            </VBox>
            <Separator styleClass="sidebar-divider"/>
            <!-- User Profile -->
            <HBox fx:id="userRow" styleClass="user-row" alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="user-avatar" text="A"/>
                <VBox fx:id="userInfo" styleClass="user-info" spacing="1">
                    <Label styleClass="user-name" text="Admin"/>
                    <Label styleClass="user-role" text="Administrator"/>
                </VBox>
            </HBox>
            <!-- Toggle Button -->
            <Button fx:id="toggleBtn" styleClass="toggle-btn"
                          text="◀" onAction="#onToggleSidebar"
                          maxWidth="Infinity" />
        </VBox>
    </left>
</BorderPane>
